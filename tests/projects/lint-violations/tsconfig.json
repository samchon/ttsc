{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",
    "plugins": [
      {
        "transform": "@ttsc/lint",
        "config": {
          "no-var": "error",
          "no-explicit-any": "warn",
          "no-non-null-assertion": "off",
          "no-debugger": "error",
          "eqeqeq": "error",
          "no-empty-interface": "warn",
          "prefer-for-of": "warn",
          "no-confusing-non-null-assertion": "error"
        }
      }
    ]
  },
  "include": ["src"]
}
