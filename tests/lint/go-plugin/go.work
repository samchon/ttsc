// Development-time go.work overlay for the lint test module.
//
// At test time, scripts/test-go-lint.cjs materializes this directory
// into a scratch dir and writes a fresh go.work with absolute paths.
// This file mirrors the same overlay using *relative* paths so editors
// and `go test ./...` from the source tree resolve symbols correctly.

go 1.26

use (
	.
	../../../packages/lint/go-plugin
	../../../packages/ttsc
	../../../packages/ttsc/shim/ast
	../../../packages/ttsc/shim/bundled
	../../../packages/ttsc/shim/checker
	../../../packages/ttsc/shim/compiler
	../../../packages/ttsc/shim/core
	../../../packages/ttsc/shim/diagnosticwriter
	../../../packages/ttsc/shim/parser
	../../../packages/ttsc/shim/scanner
	../../../packages/ttsc/shim/tsoptions
	../../../packages/ttsc/shim/tspath
	../../../packages/ttsc/shim/vfs
	../../../packages/ttsc/shim/vfs/cachedvfs
	../../../packages/ttsc/shim/vfs/osvfs
)
