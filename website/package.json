{
  "name": "@ttsc/website",
  "version": "0.18.4",
  "description": "ttsc Guide Documents, Tutorial, and Playground.",
  "private": true,
  "scripts": {
    "build": "pnpm run prebuild && pnpm run build:next && pnpm run postbuild",
    "prebuild": "rimraf .next && rimraf out && pnpm run build:compiler && pnpm run build:blog:rss && pnpm run build:benchmark:png",
    "build:next": "next build",
    "build:compiler": "node build/compiler.cjs",
    "build:blog:rss": "node build/blog.cjs",
    "test:rss-autodiscovery": "node --test test/rss-autodiscovery.test.cjs",
    "build:benchmark:graph": "node build/graph-benchmark-svg.cjs",
    "build:benchmark:png": "node build/graph-benchmark-svg.cjs --png",
    "charts:png": "node build/svg-to-png.cjs",
    "prepare": "pnpm run build:benchmark:graph",
    "postbuild": "pnpm run test:rss-autodiscovery && pnpm run build:pagefind && pnpm run build:sitemap",
    "build:pagefind": "pagefind --site .next/server/app --output-path out/_pagefind",
    "build:sitemap": "next-sitemap",
    "deploy": "node build/deploy.cjs",
    "dev": "pnpm run build:compiler && next dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/ttsc"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/ttsc/issues"
  },
  "homepage": "https://ttsc.dev",
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@ttsc/playground": "workspace:^",
    "@ttsc/wasm": "workspace:^",
    "@typia/interface": "catalog:samchon",
    "@typia/utils": "catalog:samchon",
    "lz-string": "^1.5.0",
    "monaco-editor": "^0.52.0",
    "next": "^15.1.0",
    "nextra": "4.2.17",
    "nextra-theme-docs": "4.2.17",
    "path": "^0.12.7",
    "postcss": "^8.5.6",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.1.12",
    "tgrid": "^1.0.3",
    "three": "^0.184.0",
    "three-forcegraph": "^1.43.4",
    "tstl": "^3.0.0",
    "typescript": "~5.9.3",
    "typia": "catalog:samchon"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@rspack/cli": "^1.3.0",
    "@rspack/core": "^1.3.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.1",
    "@types/three": "^0.184.1",
    "gh-pages": "^6.3.0",
    "next-sitemap": "^4.2.3",
    "pagefind": "^1.3.0",
    "process": "^0.11.10",
    "rimraf": "^6.0.1",
    "ts-loader": "^9.5.1"
  }
}
