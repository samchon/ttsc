{
  "name": "@ttsc/linux-arm",
  "version": "0.16.11",
  "description": "Linux arm native ttsc/ttscserver/ttscgraph binaries and bundled Go compiler for ttsc.",
  "os": ["linux"],
  "cpu": ["arm"],
  "scripts": {
    "build": "node ../../scripts/build-platform-package.cjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/ttsc"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "files": ["bin", "package.json", "README.md"],
  "publishConfig": {
    "access": "public",
    "executableFiles": [
      "./bin/ttsc",
      "./bin/ttscserver",
      "./bin/ttscgraph",
      "./bin/go/bin/go",
      "./bin/go/bin/gofmt"
    ]
  }
}
