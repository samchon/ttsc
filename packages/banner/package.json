{
  "name": "@ttsc/banner",
  "version": "0.14.0-dev.20260528.1",
  "description": "First-party ttsc plugin that adds package-documentation JSDoc banners during emit.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf lib && tsgo"
  },
  "keywords": [
    "ttsc",
    "banner",
    "typescript",
    "tsgo"
  ],
  "ttsc": {
    "plugin": {
      "transform": "@ttsc/banner"
    }
  },
  "files": [
    "README.md",
    "driver/banner.go",
    "lib",
    "src",
    "go.mod",
    "plugin/banner.go",
    "plugin/main.go"
  ],
  "devDependencies": {
    "@types/node": "catalog:utils",
    "@typescript/native-preview": "catalog:tsgo",
    "rimraf": "catalog:utils",
    "ttsc": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/ttsc"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/ttsc/issues"
  },
  "homepage": "https://ttsc.dev"
}
