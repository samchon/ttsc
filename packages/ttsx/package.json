{
  "name": "ttsx",
  "version": "0.1.0-dev",
  "description": "Standalone tsgo runner built on top of the ttsc host.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "ttsx": "src/launcher/ttsx.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf lib && ttsc",
    "prepack": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/ttsc"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/ttsc/issues"
  },
  "homepage": "https://github.com/samchon/ttsc",
  "dependencies": {
    "ttsc": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "catalog:utils",
    "@typescript/native-preview": "catalog:typescript",
    "rimraf": "catalog:utils"
  },
  "sideEffects": false,
  "files": [
    "README.md",
    "package.json",
    "lib",
    "src"
  ],
  "keywords": [
    "tsgo",
    "runner",
    "tsx",
    "ttsx"
  ],
  "packageManager": "pnpm@10.6.4",
  "publishConfig": {
    "access": "public",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "bin": {
      "ttsx": "src/launcher/ttsx.js"
    },
    "exports": {
      ".": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      },
      "./package.json": "./package.json"
    }
  }
}
