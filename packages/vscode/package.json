{
  "name": "@ttsc/vscode",
  "displayName": "ttsc",
  "description": "Show ttsc plugin diagnostics in VS Code, with @ttsc/lint errors, fix-all actions, and formatter support.",
  "version": "0.14.0",
  "publisher": "samchon",
  "icon": "images/icon.png",
  "license": "MIT",
  "author": "Jeongho Nam",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://ttsc.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/ttsc",
    "directory": "packages/vscode"
  },
  "bugs": {
    "url": "https://github.com/samchon/ttsc/issues"
  },
  "engines": {
    "vscode": "^1.94.0",
    "node": ">=18"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "keywords": [
    "typescript",
    "typescript-go",
    "tsgo",
    "lint",
    "linter",
    "formatter",
    "prettier",
    "lsp",
    "ttsc"
  ],
  "extensionKind": [
    "workspace"
  ],
  "main": "./lib/extension.js",
  "bin": {
    "ttsc-vscode": "./bin/install.js"
  },
  "files": [
    "bin",
    "dist",
    "images",
    "lib",
    "LICENSE",
    "README.md"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact"
  ],
  "contributes": {
    "commands": [
      {
        "command": "ttsc.lint.fixAll",
        "title": "ttsc: Fix all lint issues"
      },
      {
        "command": "ttsc.format.document",
        "title": "ttsc: Format document"
      },
      {
        "command": "ttsc.server.restart",
        "title": "ttsc: Restart language server"
      }
    ],
    "configuration": {
      "title": "ttsc",
      "properties": {
        "ttsc.serverPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to a ttscserver launcher or native binary. Leave empty to use the project ttsc launcher, which builds TTSC_LSP_PLUGINS_JSON for plugin diagnostics/actions; direct native paths need that manifest supplied out of band.",
          "scope": "resource"
        },
        "ttsc.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace LSP messages between VS Code and ttscserver."
        }
      }
    }
  },
  "scripts": {
    "build": "rimraf lib dist && node build/build.cjs"
  },
  "devDependencies": {
    "@types/node": "catalog:utils",
    "@types/vscode": "^1.94.0",
    "@typescript/native-preview": "catalog:tsgo",
    "@vscode/vsce": "^3.6.1",
    "esbuild": "^0.25.12",
    "rimraf": "catalog:utils",
    "ttsc": "workspace:*",
    "vscode-languageclient": "^9.0.1"
  }
}
