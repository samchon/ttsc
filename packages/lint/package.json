{
  "name": "@ttsc/lint",
  "version": "0.14.0-dev.20260528.1",
  "description": "Reference ttsc plugin: ESLint-style lint rules hosted in the same Program/Checker as the type-check pass.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf lib && tsgo"
  },
  "keywords": [
    "ttsc",
    "lint",
    "eslint",
    "typescript",
    "tsgo"
  ],
  "ttsc": {
    "plugin": {
      "transform": "@ttsc/lint"
    }
  },
  "files": [
    "README.md",
    "go.mod",
    "lib",
    "linthost",
    "plugin",
    "rule",
    "src"
  ],
  "devDependencies": {
    "@typescript/native-preview": "catalog:tsgo",
    "@types/node": "catalog:utils",
    "rimraf": "catalog:utils",
    "ttsc": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/ttsc"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/ttsc/issues"
  },
  "homepage": "https://ttsc.dev"
}
