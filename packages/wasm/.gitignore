# Build artifacts (also covered by repo root .gitignore but listed here for clarity).
dist/
lib/

# Pack-time vendored shim tree (regenerated by build/build-wasm.cjs).
shim-vendor/

# Native sanity binary built by `go build ./cmd/ttsc-wasm` outside the wasm cross-compile path.
# Root-anchored so it does NOT match the cmd/ttsc-wasm/ source directory.
/ttsc-wasm
