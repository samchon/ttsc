{
  "name": "ttsc",
  "version": "0.1.0-dev",
  "description": "General-purpose compiler adapter and plugin host for tsgo.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "ttsc": "src/launcher/ttsc.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf lib && node ../../scripts/go.cjs run ./cmd/ttsc",
    "test": "pnpm run test:ts && pnpm run test:go",
    "test:ts": "node --test --test-reporter=spec --experimental-strip-types --experimental-specifier-resolution=node test/**/*.test.ts",
    "test:go": "node ../../scripts/go.cjs test ./...",
    "go:build": "node ../../scripts/go.cjs build-native",
    "go:test": "node ../../scripts/go.cjs test ./...",
    "go:vet": "node ../../scripts/go.cjs vet ./...",
    "prepack": "pnpm run build && pnpm run go:build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/ttsc"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/ttsc/issues"
  },
  "homepage": "https://github.com/samchon/ttsc",
  "devDependencies": {
    "@types/node": "catalog:utils",
    "@typescript/native-preview": "catalog:typescript",
    "rimraf": "catalog:utils"
  },
  "optionalDependencies": {
    "@ttsc/linux-x64": "workspace:*",
    "@ttsc/linux-arm64": "workspace:*",
    "@ttsc/darwin-x64": "workspace:*",
    "@ttsc/darwin-arm64": "workspace:*",
    "@ttsc/win32-x64": "workspace:*",
    "@ttsc/win32-arm64": "workspace:*"
  },
  "sideEffects": false,
  "files": [
    "README.md",
    "cmd",
    "driver",
    "go.mod",
    "go.sum",
    "package.json",
    "lib",
    "shim",
    "src",
    "test",
    "tools"
  ],
  "keywords": [
    "tsgo",
    "transformer",
    "plugin-host",
    "ttsc"
  ],
  "packageManager": "pnpm@10.6.4",
  "publishConfig": {
    "access": "public",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "bin": {
      "ttsc": "src/launcher/ttsc.js"
    },
    "exports": {
      ".": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      },
      "./package.json": "./package.json"
    }
  }
}
