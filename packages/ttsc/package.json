{
  "name": "ttsc",
  "version": "0.7.1",
  "description": "General-purpose TypeScript-Go compiler, plugin host, and runtime.",
  "main": "lib/index.js",
  "types": "src/index.ts",
  "bin": {
    "ttsc": "lib/launcher/ttsc.js",
    "ttsx": "lib/launcher/ttsx.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "exports": {
      ".": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "rimraf lib && tsgo && cp ../../README.md README.md",
    "test": "pnpm run test:ts && pnpm run test:go",
    "test:ts": "node --test --test-reporter=spec --experimental-strip-types --experimental-specifier-resolution=node test/**/*.test.ts",
    "test:go": "node ../../scripts/go.cjs test ./...",
    "go:build": "node ../../scripts/go.cjs build-native",
    "go:test": "node ../../scripts/go.cjs test ./...",
    "go:vet": "node ../../scripts/go.cjs vet ./..."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/ttsc"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/ttsc/issues"
  },
  "homepage": "https://github.com/samchon/ttsc",
  "devDependencies": {
    "@types/node": "catalog:utils",
    "@typescript/native-preview": "catalog:tsgo",
    "rimraf": "catalog:utils"
  },
  "optionalDependencies": {
    "@ttsc/linux-x64": "workspace:*",
    "@ttsc/linux-arm": "workspace:*",
    "@ttsc/linux-arm64": "workspace:*",
    "@ttsc/darwin-x64": "workspace:*",
    "@ttsc/darwin-arm64": "workspace:*",
    "@ttsc/win32-x64": "workspace:*",
    "@ttsc/win32-arm64": "workspace:*"
  },
  "sideEffects": false,
  "files": [
    "README.md",
    "cmd",
    "driver",
    "go.mod",
    "go.sum",
    "package.json",
    "lib",
    "shim",
    "src",
    "test",
    "tools"
  ],
  "keywords": [
    "tsgo",
    "runner",
    "transformer",
    "plugin-host",
    "ttsc"
  ],
  "packageManager": "pnpm@10.6.4"
}
