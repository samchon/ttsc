{
  "name": "@ttsc/graph",
  "version": "0.19.1",
  "description": "Checker-resolved architecture graph over MCP for coding agents, backed by ttsc's in-process TypeScript-Go compiler.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "bin": {
    "ttsc-graph": "lib/bin.js"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf lib && node node_modules/ttsc/lib/launcher/ttsc.js && node build/bundle-viewer.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@typia/mcp": "catalog:samchon",
    "typia": "catalog:samchon"
  },
  "keywords": [
    "ttsc",
    "mcp",
    "code-graph",
    "typescript",
    "tsgo"
  ],
  "files": [
    "README.md",
    "lib",
    "src"
  ],
  "devDependencies": {
    "@types/node": "catalog:utils",
    "@types/three": "^0.184.1",
    "esbuild": "^0.25.12",
    "rimraf": "catalog:utils",
    "three": "^0.184.0",
    "three-forcegraph": "^1.43.4",
    "ttsc": "workspace:*",
    "typescript": "catalog:typescript"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/ttsc"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/ttsc/issues"
  },
  "homepage": "https://ttsc.dev"
}
