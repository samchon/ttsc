{
  "name": "@ttsc/unplugin",
  "version": "0.19.4",
  "description": "Bundler adapters for ttsc plugins.",
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "default": "./lib/index.js"
    },
    "./api": {
      "types": "./lib/api.d.ts",
      "import": "./lib/api.mjs",
      "default": "./lib/api.js"
    },
    "./bun": {
      "types": "./lib/bun.d.ts",
      "import": "./lib/bun.mjs",
      "default": "./lib/bun.js"
    },
    "./bun-register": {
      "types": "./lib/bun-register.d.ts",
      "import": "./lib/bun-register.mjs",
      "default": "./lib/bun-register.js"
    },
    "./esbuild": {
      "types": "./lib/esbuild.d.ts",
      "import": "./lib/esbuild.mjs",
      "default": "./lib/esbuild.js"
    },
    "./farm": {
      "types": "./lib/farm.d.ts",
      "import": "./lib/farm.mjs",
      "default": "./lib/farm.js"
    },
    "./next": {
      "types": "./lib/next.d.ts",
      "import": "./lib/next.mjs",
      "default": "./lib/next.js"
    },
    "./rolldown": {
      "types": "./lib/rolldown.d.ts",
      "import": "./lib/rolldown.mjs",
      "default": "./lib/rolldown.js"
    },
    "./rollup": {
      "types": "./lib/rollup.d.ts",
      "import": "./lib/rollup.mjs",
      "default": "./lib/rollup.js"
    },
    "./rspack": {
      "types": "./lib/rspack.d.ts",
      "import": "./lib/rspack.mjs",
      "default": "./lib/rspack.js"
    },
    "./turbopack": {
      "types": "./lib/turbopack.d.ts",
      "import": "./lib/turbopack.mjs",
      "default": "./lib/turbopack.js"
    },
    "./vite": {
      "types": "./lib/vite.d.ts",
      "import": "./lib/vite.mjs",
      "default": "./lib/vite.js"
    },
    "./webpack": {
      "types": "./lib/webpack.d.ts",
      "import": "./lib/webpack.mjs",
      "default": "./lib/webpack.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf lib && tsc --emitDeclarationOnly && rollup -c"
  },
  "keywords": [
    "ttsc",
    "unplugin",
    "vite",
    "esbuild",
    "rollup",
    "webpack",
    "typescript",
    "tsgo"
  ],
  "files": [
    "README.md",
    "lib",
    "src"
  ],
  "dependencies": {
    "unplugin": "^2.3.11"
  },
  "peerDependencies": {
    "ttsc": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/node": "catalog:utils",
    "esbuild": "^0.25.12",
    "rimraf": "catalog:utils",
    "rollup": "^4.60.3",
    "tinyglobby": "^0.2.16",
    "tslib": "^2.8.1",
    "ttsc": "workspace:*",
    "typescript": "catalog:typescript",
    "vite": "^7.1.12"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/ttsc"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/ttsc/issues"
  },
  "homepage": "https://ttsc.dev",
  "sideEffects": false,
  "packageManager": "pnpm@10.6.4"
}
