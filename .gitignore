# Dependencies and package manager state
node_modules/

# Build outputs
lib/
native/
dist/
bin/
!packages/vscode/bin/
coverage/

# Local caches and package archives
.cache/
.turbo/
.campaign-tmp/
*.tgz
*.tsbuildinfo
*.log

# AI assistant data
.claude/
.discussions/
.playwright-mcp/

# Local Go workspace overlays
go.work
go.work.sum

# Reference and experiment checkouts
.references/
.wiki/
.work/
experimental/typia/
experimental/nestia/

# Benchmark results — an ephemeral artifact, never committed.
experimental/benchmark/.work/

# Promotional media. Clips are rendered locally, published as GitHub-hosted
# attachments, and referenced by URL from the website, so no binary enters the
# repository. The toolchain that produces them is tracked, because media nobody
# can regenerate goes stale silently, and the URL map with it.
/.media/*
!/.media/tools/
!/.media/urls.json
/.media/tools/node_modules/
/.media/tools/*.exe
/.media/tools/*.zip
/.media/tools/ffmpeg-master-latest-win64-gpl/
/.media/tools/picks.json

# Stray native sanity binary from `go build ./cmd/ttsc-wasm` (host build).
packages/wasm/ttsc-wasm

# Stray native sanity binary from `go build packages/lint/plugin` invoked from repo root.
/plugin
# Stray native sanity binary from `go build website/compiler/cmd/playground` invoked from website/compiler.
website/compiler/playground

# Compiled Go binaries left by `go build .` in the cmd directory.
packages/ttsc/cmd/ttsc/ttsc
